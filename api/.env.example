# ── Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/jamb_allocator?sslmode=require

# ── Auth
JWT_SECRET=your-super-secret-jwt-key
NODE_ENV=development
PORT=3001

# ── Email (SendGrid)
# Get from sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@jamb.gov.ng
SENDGRID_FROM_NAME=JAMB CBT Allocation

# ── WhatsApp (Meta Cloud API — free 1,000 conversations/month)
# Setup: developers.facebook.com → My Apps → WhatsApp → Getting Started
# 1. Create a Meta App (Business type)
# 2. Add WhatsApp product
# 3. Copy the temporary access token → WHATSAPP_TOKEN
# 4. Copy the Phone Number ID → WHATSAPP_PHONE_ID
# 5. Add test numbers in: WhatsApp → API Setup → To field
WHATSAPP_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id

# ── CORS
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
