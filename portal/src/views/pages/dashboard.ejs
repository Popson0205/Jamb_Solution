<%
const body = `
<div class="topbar">
  <div>
    <div class="topbar-title">Dashboard</div>
    <div class="topbar-subtitle">Overview of all allocations and centres</div>
  </div>
  <div class="topbar-actions">
    <a href="/allocations/export" class="export-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </a>
  </div>
</div>
<div class="content">
  <!-- Stats -->
  <div class="stats-grid">
    <div class="stat-card">
      <div>
        <div class="stat-label">Total Students</div>
        <div class="stat-value">${summary.total_students?.toLocaleString() || 0}</div>
        <div class="stat-change">Registered candidates</div>
      </div>
      <div class="stat-icon green">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
    </div>
    <div class="stat-card">
      <div>
        <div class="stat-label">Total Allocations</div>
        <div class="stat-value">${summary.total_allocations?.toLocaleString() || 0}</div>
        <div class="stat-change">Centres assigned</div>
      </div>
      <div class="stat-icon blue">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
      </div>
    </div>
    <div class="stat-card">
      <div>
        <div class="stat-label">Active Centres</div>
        <div class="stat-value">${summary.total_centres?.toLocaleString() || 0}</div>
        <div class="stat-change">Across all states</div>
      </div>
      <div class="stat-icon orange">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
      </div>
    </div>
    <div class="stat-card">
      <div>
        <div class="stat-label">Fill Rate</div>
        <div class="stat-value">${summary.total_centres > 0 ? Math.round((summary.total_allocations / (summary.total_centres * 150)) * 100) : 0}%</div>
        <div class="stat-change">Capacity utilisation</div>
      </div>
      <div class="stat-icon purple">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      </div>
    </div>
  </div>

  <!-- Charts -->
  <div class="charts-grid">
    <div class="card">
      <div class="card-header"><span class="card-title">Students by Batch</span></div>
      <div class="card-body"><div class="chart-container"><canvas id="batchChart"></canvas></div></div>
    </div>
    <div class="card">
      <div class="card-header"><span class="card-title">Top Centres by Allocation</span></div>
      <div class="card-body"><div class="chart-container"><canvas id="centresChart"></canvas></div></div>
    </div>
  </div>

  <!-- Recent allocations preview -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Batch Breakdown</span>
      <a href="/allocations" class="btn btn-sm btn-secondary">View All</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Batch</th><th>Students</th><th>Time</th></tr></thead>
        <tbody>
          ${(summary.batch_breakdown || []).map(b => `
          <tr>
            <td><span class="badge badge-green">Batch ${b.batch_number}</span></td>
            <td class="td-name">${parseInt(b.count).toLocaleString()}</td>
            <td>${b.batch_number == 1 ? '08:30 – 10:30' : b.batch_number == 2 ? '11:00 – 13:00' : b.batch_number == 3 ? '13:30 – 15:30' : '16:00 – 18:00'}</td>
          </tr>`).join('') || '<tr><td colspan="3" style="text-align:center;color:#888;padding:20px">No allocations yet</td></tr>'}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
const batchData = ${JSON.stringify(summary.batch_breakdown || [])};
const centresData = ${JSON.stringify(summary.top_centres_by_fill || [])};

// Batch pie chart
new Chart(document.getElementById('batchChart'), {
  type: 'doughnut',
  data: {
    labels: batchData.map(b => 'Batch ' + b.batch_number),
    datasets: [{ data: batchData.map(b => parseInt(b.count)), backgroundColor: ['#006400','#2e7d32','#4caf50','#81c784'], borderWidth: 0 }]
  },
  options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } } }
});

// Centres bar chart
new Chart(document.getElementById('centresChart'), {
  type: 'bar',
  data: {
    labels: centresData.map(c => c.name.substring(0, 20) + '...'),
    datasets: [
      { label: 'Allocated', data: centresData.map(c => parseInt(c.allocated)), backgroundColor: '#006400' },
      { label: 'Capacity', data: centresData.map(c => c.capacity_per_batch), backgroundColor: '#e8f5e9' }
    ]
  },
  options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } }, scales: { x: { grid: { display: false } } } }
});
</script>
`;
%>
<%- include('../partials/layout', { title: 'Dashboard — JAMB Admin', body, user, page }) %>
