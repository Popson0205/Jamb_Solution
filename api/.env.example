# Neon connection string — get from neon.tech → project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/jamb_allocator?sslmode=require

JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
PORT=3001

TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=JAMB

SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@jamb.gov.ng
SENDGRID_FROM_NAME=JAMB CBT Allocator

CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ── Twilio (SMS)
# Get from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+12345678901
