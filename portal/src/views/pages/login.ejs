<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JAMB Admin Portal — Login</title>
  <link rel="stylesheet" href="/css/portal.css">
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div class="login-logo">
      <div class="crest">🎓</div>
      <h1>JAMB CBT Admin Portal</h1>
      <p>Allocation Management System</p>
    </div>
    <% if (error) { %>
      <div class="alert alert-error" style="margin-bottom:20px"><%= error %></div>
    <% } %>
    <form method="POST" action="/login">
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="admin@jamb.gov.ng" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:10px">Sign In</button>
    </form>
  </div>
</div>
</body>
</html>
