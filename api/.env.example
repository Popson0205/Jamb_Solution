# ── Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/jamb_allocator?sslmode=require

# ── Auth
JWT_SECRET=your-super-secret-jwt-key
NODE_ENV=development
PORT=3001

# ── SMS via Twilio (free trial at twilio.com)
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+12345678901
# Note: Twilio trial only sends to VERIFIED numbers
# Add numbers at: console.twilio.com → Phone Numbers → Verified Caller IDs

# ── Email via SendGrid (free 100/day at sendgrid.com)
# Get from: app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=Idrispopoola02@gmail.com
SENDGRID_FROM_NAME=JAMB CBT Allocation

# ── CORS
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
